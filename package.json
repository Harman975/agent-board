{
  "name": "agentboard",
  "version": "0.1.0",
  "description": "A Twitter-like feed for supervising AI agents",
  "type": "module",
  "bin": {
    "board": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agents",
    "supervision",
    "dashboard",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Harman975/agent-board.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "board": "node --import tsx src/cli.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "hono": "^4.12.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
